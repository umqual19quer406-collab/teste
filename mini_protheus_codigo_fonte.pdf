T*
(0029: AFTER INSERT) Tj
T*
(0030: AS) Tj
T*
(0031: BEGIN) Tj
T*
(0032:     SET NOCOUNT ON;) Tj
T*
(0033:     IF EXISTS \() Tj
T*
(0034:         SELECT 1) Tj
T*
(0035:         FROM inserted i) Tj
T*
(0036:         WHERE dbo.fn_periodo_fechado\(i.D3_FILIAL, CAST\(i.D3_DATA AS DATE\)\) = 1) Tj
T*
(0037:     \)) Tj
T*
(0038:     BEGIN) Tj
