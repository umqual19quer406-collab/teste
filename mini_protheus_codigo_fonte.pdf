T*
(0001: from datetime import datetime, timedelta, timezone) Tj
T*
(0002: from fastapi import Depends, HTTPException) Tj
T*
(0003: from fastapi.security import OAuth2PasswordBearer) Tj
T*
(0004: from jose import jwt, JWTError) Tj
T*
(0005: ) Tj
T*
(0006: from app.core import settings) Tj
T*
(0007: from app.infra.db import set_current_user) Tj
T*
(0008: ) Tj
T*
(0009: oauth2_scheme = OAuth2PasswordBearer\(tokenUrl="login"\)) Tj
T*
(0010: ) Tj
T*
(0011: ) Tj
T*
(0012: def create_access_token\(data: dict, expires_minutes: int = settings.JWT_EXPIRE_MINUTES\) -> str) Tj
T*
(:) Tj
T*
(0013:     to_encode = data.copy\(\)) Tj
T*
(0014:     expire = datetime.now\(timezone.utc\) + timedelta\(minutes=expires_minutes\)) Tj
T*
(0015:     to_encode.update\({"exp": expire}\)) Tj
T*
(0016:     return jwt.encode\(to_encode, settings.JWT_SECRET_KEY, algorithm=settings.JWT_ALGORITHM\)) Tj
T*
(0017: ) Tj
T*
(0018: ) Tj
T*
(0019: def get_current_user\(token: str = Depends\(oauth2_scheme\)\) -> dict:) Tj
T*
(0020:     try:) Tj
T*
(0021:         payload = jwt.decode\() Tj
T*
(0022:             token,) Tj
T*
(0023:             settings.JWT_SECRET_KEY,) Tj
T*
(0024:             algorithms=[settings.JWT_ALGORITHM],) Tj
T*
(0025:         \)) Tj
T*
(0026:         login: str = payload.get\("sub"\)) Tj
T*
(0027:         perfil: str = payload.get\("perfil"\)) Tj
T*
(0028:         if not login or not perfil:) Tj
T*
(0029:             raise HTTPException\(status_code=401, detail="Token inválido"\)) Tj
T*
(0030:         set_current_user\(login\)) Tj
T*
(0031:         return {"login": login, "perfil": perfil}) Tj
T*
(0032:     except JWTError:) Tj
T*
(0033:         raise HTTPException\(status_code=401, detail="Token inválido ou expirado"\)) Tj
T*
() Tj
T*
