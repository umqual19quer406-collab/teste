(0148: def split_pages\(lines: list[str], max_lines: int = 54\) -> list[list[str]]:) Tj
T*
(0149:     pages: list[list[str]] = []) Tj
T*
(0150:     current: list[str] = []) Tj
T*
(0151:     line_count = 0) Tj
T*
(0152:     for line in lines:) Tj
T*
(0153:         wrapped = wrap_line\(line, width=100\)) Tj
T*
(0154:         if line_count + len\(wrapped\) > max_lines and current:) Tj
T*
(0155:             pages.append\(current\)) Tj
T*
(0156:             current = []) Tj
T*
(0157:             line_count = 0) Tj
T*
(0158:         current.extend\(wrapped\)) Tj
T*
(0159:         line_count += len\(wrapped\)) Tj
T*
(0160:     if current:) Tj
T*
(0161:         pages.append\(current\)) Tj
T*
(0162:     return pages) Tj
T*
(0163: ) Tj
T*
(0164: ) Tj
T*
(0165: def wrap_line\(text: str, width: int\) -> list[str]:) Tj
T*
(0166:     normalized = normalize_text\(text\)) Tj
T*
(0167:     if len\(normalized\) <= width:) Tj
T*
(0168:         return [normalized]) Tj
T*
(0169:     parts = []) Tj
T*
(0170:     remaining = normalized) Tj
T*
(0171:     while len\(remaining\) > width:) Tj
T*
(0172:         parts.append\(remaining[:width]\)) Tj
T*
(0173:         remaining = remaining[width:]) Tj
T*
(0174:     if remaining:) Tj
T*
(0175:         parts.append\(remaining\)) Tj
T*
(0176:     return parts) Tj
T*
(0177: ) Tj
T*
(0178: ) Tj
T*
(0179: def make_stream\(page_lines: list[str], page_number: int, total_pages: int\) -> bytes:) Tj
T*
(0180:     commands = ["BT", "/F1 9 Tf", "50 790 Td", "12 TL"]) Tj
T*
(0181:     for line in page_lines:) Tj
T*
(0182:         commands.append\(f"\({escape_pdf_text\(line\)}\) Tj"\)) Tj
T*
(0183:         commands.append\("T*"\)) Tj
T*
(0184:     commands.append\("T*"\)) Tj
T*
(0185:     commands.append\(f"\(Pagina {page_number}/{total_pages}\) Tj"\)) Tj
T*
(0186:     commands.append\("ET"\)) Tj
T*
(0187:     body = "\\n".join\(commands\).encode\("cp1252", "replace"\)) Tj
T*
(0188:     return f"<< /Length {len\(body\)} >>\\nstream\\n".encode\("ascii"\) + body + b"\\nendstream") Tj
T*
(0189: ) Tj
T*
(0190: ) Tj
T*
