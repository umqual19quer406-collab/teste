T*
(0131:         "",) Tj
T*
(0132:     ]) Tj
T*
(0133:     for path in files:) Tj
T*
(0134:         relative = path.relative_to\(root\).as_posix\(\)) Tj
T*
(0135:         lines.append\("=" * 100\)) Tj
T*
