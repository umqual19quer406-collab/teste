(0043: @contextmanager ) Tj
T*
(0044: def db_transaction\(\) -> Iterator[Tuple[pyodbc.Connection, pyodbc.Cursor]]: ) Tj
T*
(0045:     conn = get_connection\(\) ) Tj
T*
(0046:     cur = conn.cursor\(\) ) Tj
T*
(0047:     try: ) Tj
T*
(0048:         cur.execute\("SET NOCOUNT ON;"\) ) Tj
T*
(0049:         user = get_current_user_ctx\(\)) Tj
T*
(0050:         if user:) Tj
T*
(0051:             # registra usuário da sessăo para auditoria via trigger) Tj
T*
(0052:             cur.execute\("EXEC sp_set_session_context @key=N'app_user', @value=?", \(user,\)\)) Tj
T*
(0053:         req_id = get_current_request_id\(\)) Tj
T*
(0054:         req_path = get_current_request_path\(\)) Tj
T*
(0055:         if req_id:) Tj
T*
(0056:             cur.execute\("EXEC sp_set_session_context @key=N'app_req_id', @value=?", \(req_id,\)\)) Tj
T*
(0057:         if req_path:) Tj
T*
(0058:             cur.execute\("EXEC sp_set_session_context @key=N'app_path', @value=?", \(req_path,\)\)) Tj
T*
(0059:         yield conn, cur ) Tj
T*
(0060:         conn.commit\(\) ) Tj
T*
(0061:     except Exception: ) Tj
T*
(0062:         conn.rollback\(\) ) Tj
T*
(0063:         raise ) Tj
T*
(0064:     finally: ) Tj
T*
(0065:         try: ) Tj
T*
(0066:             cur.close\(\) ) Tj
T*
(0067:         finally: ) Tj
T*
(0068:             conn.close\(\) ) Tj
T*
(0069:  ) Tj
T*
