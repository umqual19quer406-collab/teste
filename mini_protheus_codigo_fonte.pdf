stream
BT
/F1 9 Tf
50 790 Td
12 TL
(0001: -- Bloco 6.3 - Correçőes automáticas \(consistęncia\)) Tj
T*
(0002: -- Execute no ERP_PROTHEUS. Script conservador \(năo mexe em AR baixado\).) Tj
T*
(0003: ) Tj
T*
(0004: SET NOCOUNT ON;) Tj
T*
(0005: ) Tj
T*
(0006: -- 1\) Preencher C6_ITEM faltante \(por pedido\) - dinâmico) Tj
T*
(0007: EXEC\(') Tj
T*
(0008: ;WITH ItensOrdenados AS \() Tj
T*
(0009:     SELECT ID, C6_PEDIDO_ID,) Tj
T*
(0010:            ROW_NUMBER\(\) OVER \(PARTITION BY C6_PEDIDO_ID ORDER BY ID ASC\) AS rn) Tj
T*
(0011:     FROM dbo.SC6_ITENS) Tj
T*
(0012:     WHERE C6_ITEM IS NULL) Tj
T*
(0013: \)) Tj
T*
(0014: UPDATE i SET C6_ITEM = rn) Tj
T*
(0015: FROM ItensOrdenados i;) Tj
T*
(0016: '\);) Tj
T*
(0017: ) Tj
T*
(0018: -- 2\) Preencher D2_ITEM_NUM faltante \(por NF\) - dinâmico) Tj
T*
(0019: EXEC\(') Tj
T*
(0020: ;WITH ItensNF AS \() Tj
T*
(0021:     SELECT ID, D2_NF_ID,) Tj
T*
(0022:            ROW_NUMBER\(\) OVER \(PARTITION BY D2_NF_ID ORDER BY ID ASC\) AS rn) Tj
T*
(0023:     FROM dbo.SD2_ITENS) Tj
T*
(0024:     WHERE D2_ITEM_NUM IS NULL) Tj
T*
(0025: \)) Tj
T*
(0026: UPDATE d) Tj
T*
(0027: SET D2_ITEM_NUM = RIGHT\(''0000'' + CAST\(rn AS VARCHAR\(4\)\), 4\)) Tj
T*
(0028: FROM ItensNF d;) Tj
T*
(0029: '\);) Tj
T*
(0030: ) Tj
T*
(0031: -- 3\) Se NF cancelada, marca SD2 como cancelado \(somente ativos\)) Tj
T*
(0032: UPDATE d) Tj
T*
(0033: SET d.D2_STATUS='CANCELADO',) Tj
T*
(0034:     d.D2_DATA_CANCEL=COALESCE\(d.D2_DATA_CANCEL, SYSDATETIME\(\)\),) Tj
T*
(0035:     d.D2_MOTIVO_CANCEL=COALESCE\(d.D2_MOTIVO_CANCEL, 'AUTO: NF cancelada'\),) Tj
T*
(0036:     d.D_E_L_E_T_='*',) Tj
T*
(0037:     d.R_E_C_D_E_L_=COALESCE\(d.R_E_C_D_E_L_, d.R_E_C_N_O_\)) Tj
T*
(0038: FROM dbo.SD2_ITENS d) Tj
T*
(0039: JOIN dbo.SF2_NOTAS f2 ON f2.ID = d.D2_NF_ID) Tj
T*
(0040: WHERE f2.F2_STATUS='CANCELADA') Tj
T*
(0041:   AND \(d.D2_STATUS IS NULL OR d.D2_STATUS <> 'CANCELADO'\);) Tj
T*
(0042: ) Tj
T*
(0043: -- 4\) Se NF cancelada, cancela AR aberto vinculado \(năo mexe em BAIXADO\)) Tj
T*
(0044: UPDATE e1) Tj
T*
(0045: SET e1.E1_STATUS='CANCELADO',) Tj
T*
(0046:     e1.D_E_L_E_T_='*',) Tj
T*
