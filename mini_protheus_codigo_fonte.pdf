T*
(0013: \)) Tj
T*
(0014: ) Tj
T*
(0015: tables = pd.read_sql\() Tj
T*
(0016:     "SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%';",) Tj
T*
(0017:     sqlite_engine) Tj
T*
(0018: \)) Tj
T*
(0019: ) Tj
T*
(0020: for t in tables["name"]:) Tj
T*
(0021:     df = pd.read_sql\(f"SELECT * FROM {t}", sqlite_engine\)) Tj
T*
(0022:     df.to_sql\(t, mssql_engine, if_exists="replace", index=False\)) Tj
T*
(0023:     print\("Migrado:", t\)) Tj
T*
(0024: ) Tj
T*
(0025: print\("Migraçăo concluída."\)) Tj
T*
() Tj
T*
