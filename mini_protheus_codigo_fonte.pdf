(0072: def maybe_fix_mojibake\(value: str\) -> str:) Tj
T*
(0073:     if not any\(marker in value for marker in MOJIBAKE_MARKERS\):) Tj
T*
(0074:         return value) Tj
T*
(0075: ) Tj
T*
(0076:     repaired = value) Tj
T*
(0077:     for _ in range\(2\):) Tj
T*
(0078:         try:) Tj
T*
(0079:             candidate = repaired.encode\("latin-1"\).decode\("utf-8"\)) Tj
T*
(0080:         except UnicodeError:) Tj
T*
(0081:             break) Tj
T*
(0082:         if candidate == repaired:) Tj
T*
(0083:             break) Tj
T*
(0084:         old_hits = sum\(repaired.count\(marker\) for marker in MOJIBAKE_MARKERS\)) Tj
T*
(0085:         new_hits = sum\(candidate.count\(marker\) for marker in MOJIBAKE_MARKERS\)) Tj
T*
(0086:         if new_hits >= old_hits:) Tj
T*
(0087:             break) Tj
T*
(0088:         repaired = candidate) Tj
T*
(0089:     return repaired) Tj
T*
