(0092: def discover_files\(root: Path\) -> list[Path]:) Tj
T*
(0093:     files: list[Path] = []) Tj
T*
(0094:     for path in sorted\(root.rglob\("*"\)\):) Tj
T*
(0095:         if not path.is_file\(\):) Tj
T*
(0096:             continue) Tj
T*
(0097:         relative = path.relative_to\(root\)) Tj
T*
(0098:         if any\(part in EXCLUDED_DIRS for part in relative.parts\):) Tj
T*
(0099:             continue) Tj
T*
(0100:         if path.suffix.lower\(\) in EXCLUDED_SUFFIXES:) Tj
T*
(0101:             continue) Tj
T*
(0102:         if path.name in INCLUDE_FILENAMES or path.suffix.lower\(\) in INCLUDE_EXTENSIONS:) Tj
T*
(0103:             files.append\(path\)) Tj
T*
(0104:     return files) Tj
T*
(0105: ) Tj
T*
(0106: ) Tj
T*
(0107: def read_source\(path: Path\) -> str:) Tj
T*
(0108:     data = path.read_bytes\(\)) Tj
T*
(0109:     for encoding in \("utf-8-sig", "utf-8", "cp1252", "latin-1"\):) Tj
T*
(0110:         try:) Tj
T*
(0111:             text = data.decode\(encoding\)) Tj
T*
(0112:             break) Tj
T*
(0113:         except UnicodeDecodeError:) Tj
T*
(0114:             continue) Tj
T*
(0115:     else:) Tj
T*
(0116:         text = data.decode\("utf-8", errors="replace"\)) Tj
T*
(0117: ) Tj
T*
(0118:     text = maybe_fix_mojibake\(text\)) Tj
T*
(0119:     text = text.replace\("\\r\\n", "\\n"\).replace\("\\r", "\\n"\)) Tj
T*
(0120:     if not text.endswith\("\\n"\):) Tj
T*
(0121:         text += "\\n") Tj
T*
(0122:     return text) Tj
T*
(0123: ) Tj
T*
(0124: ) Tj
T*
