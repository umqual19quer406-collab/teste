T*
(0007: 3\) Depois aponte TEST_DB_CONN_STR para @test_db.) Tj
T*
(0008: 4\) Rode: python tests/init_integration_db.py) Tj
T*
(0009: ) Tj
T*
(0010: Observaçőes:) Tj
T*
(0011: - Este script NĂO altera a base de origem.) Tj
T*
(0012: - Ele só cria a base de testes se ela ainda năo existir.) Tj
T*
(0013: - A base criada nasce vazia; o schema mínimo usado pelos testes é inicializado) Tj
T*
(0014:   pelo script Python tests/init_integration_db.py.) Tj
T*
(0015: */) Tj
T*
(0016: ) Tj
T*
(0017: SET NOCOUNT ON;) Tj
T*
(0018: ) Tj
T*
(0019: DECLARE @source_db sysname = N'ERP_PROTHEUS';) Tj
T*
(0020: DECLARE @test_db   sysname = N'ERP_PROTHEUS_TEST';) Tj
T*
(0021: ) Tj
T*
(0022: IF DB_ID\(@source_db\) IS NULL) Tj
T*
(0023: BEGIN) Tj
T*
(0024:     RAISERROR\('Base de origem năo encontrada: %s', 16, 1, @source_db\);) Tj
T*
(0025:     RETURN;) Tj
T*
(0026: END;) Tj
T*
(0027: ) Tj
T*
(0028: IF DB_ID\(@test_db\) IS NOT NULL) Tj
T*
(0029: BEGIN) Tj
T*
(0030:     PRINT 'Base de testes já existe: ' + @test_db;) Tj
T*
(0031:     RETURN;) Tj
T*
(0032: END;) Tj
T*
(0033: ) Tj
T*
(0034: DECLARE @data_path nvarchar\(4000\);) Tj
T*
(0035: DECLARE @log_path nvarchar\(4000\);) Tj
T*
T*
