(0008: CREATE FUNCTION dbo.fn_periodo_fechado \(@filial NVARCHAR\(10\), @data DATE\)) Tj
T*
(0009: RETURNS BIT) Tj
T*
(0010: AS) Tj
T*
(0011: BEGIN) Tj
T*
(0012:     DECLARE @fechado BIT = 0;) Tj
T*
(0013:     SELECT TOP 1 @fechado = F7_FECHADO) Tj
T*
(0014:     FROM dbo.SF7_FECHAMENTO) Tj
T*
(0015:     WHERE F7_FILIAL=@filial) Tj
T*
(0016:       AND F7_ANO=YEAR\(@data\)) Tj
T*
(0017:       AND F7_MES=MONTH\(@data\)) Tj
T*
(0018:       AND \(D_E_L_E_T_ IS NULL OR D_E_L_E_T_ <> '*'\);) Tj
T*
(0019:     RETURN ISNULL\(@fechado, 0\);) Tj
T*
(0020: END) Tj
T*
(0021: GO) Tj
T*
(0022: ) Tj
T*
