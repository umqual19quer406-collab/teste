T*
(0038:     where_sql = \("WHERE " + " AND ".join\(filtros\)\) if filtros else "" ) Tj
T*
(0039:  ) Tj
T*
(0040:     # Observaçőes: ) Tj
T*
(0041:     # - AggSC6 agrega itens por pedido ) Tj
T*
(0042:     # - ARLast pega o último título por pedido \(maior ID\) ) Tj
T*
(0043:     # - ARStat calcula status consolidado \(BAIXADO > ABERTO > CANCELADO\) ) Tj
T*
(0044:     cur.execute\( ) Tj
T*
(0045:         f""" ) Tj
T*
(0046:         WITH AggSC6 AS \( ) Tj
T*
(0047:           SELECT ) Tj
T*
(0048:             C6_PEDIDO_ID, ) Tj
T*
(0049:             SUM\(CAST\(C6_QTD AS INT\)\) AS qtd_itens, ) Tj
T*
(0050:             SUM\(CAST\(COALESCE\(C6_TOTAL, C6_VALOR, 0\) AS FLOAT\)\) AS valor_itens ) Tj
T*
(0051:           FROM dbo.SC6_ITENS ) Tj
T*
(0052:           WHERE \(D_E_L_E_T_ IS NULL OR D_E_L_E_T_ <> '*'\) ) Tj
T*
(0053:           GROUP BY C6_PEDIDO_ID ) Tj
T*
(0054:         \), ) Tj
T*
(0055:         ARJoin AS \( ) Tj
T*
(0056:           SELECT ) Tj
T*
(0057:             f2.F2_PEDIDO_ID AS pedido_id, ) Tj
T*
(0058:             e1.* ) Tj
T*
(0059:           FROM dbo.SE1_AR e1 ) Tj
T*
(0060:           INNER JOIN dbo.SF2_NOTAS f2 ON f2.ID = TRY_CAST\(e1.E1_REF AS INT\) ) Tj
T*
(0061:           WHERE \(e1.D_E_L_E_T_ IS NULL OR e1.D_E_L_E_T_ <> '*'\) ) Tj
T*
(0062:         \), ) Tj
T*
(0063:         ARLast AS \( ) Tj
T*
(0064:           SELECT a.* ) Tj
T*
(0065:           FROM ARJoin a ) Tj
T*
(0066:           JOIN \( ) Tj
T*
(0067:             SELECT pedido_id, MAX\(ID\) AS max_id ) Tj
T*
(0068:             FROM ARJoin ) Tj
T*
(0069:             GROUP BY pedido_id ) Tj
T*
(0070:           \) x ON x.pedido_id = a.pedido_id AND x.max_id = a.ID ) Tj
T*
(0071:         \), ) Tj
T*
(0072:         ARStat AS \( ) Tj
T*
(0073:           SELECT ) Tj
T*
(0074:             pedido_id, ) Tj
T*
(0075:             CASE ) Tj
T*
(0076:               WHEN SUM\(CASE WHEN E1_STATUS='BAIXADO' THEN 1 ELSE 0 END\) > 0 THEN 'BAIXADO' ) Tj
T*
(0077:               WHEN SUM\(CASE WHEN E1_STATUS='ABERTO'  THEN 1 ELSE 0 END\) > 0 THEN 'ABERTO' ) Tj
T*
(0078:               WHEN SUM\(CASE WHEN E1_STATUS='CANCELADO' THEN 1 ELSE 0 END\) > 0 THEN 'CANCELADO') Tj
T*
( ) Tj
T*
(0079:               ELSE NULL ) Tj
T*
(0080:             END AS ar_status ) Tj
T*
(0081:           FROM ARJoin ) Tj
T*
(0082:           GROUP BY pedido_id ) Tj
T*
(0083:         \) ) Tj
T*
(0084:         SELECT ) Tj
T*
T*
(Pagina 112/569) Tj
ET
endstream
