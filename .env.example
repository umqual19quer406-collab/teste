APP_TITLE=Mini Protheus - ERP (SQL Server + JWT)
APP_ENV=development
# development only
# production requires a unique non-default secret
JWT_SECRET_KEY=change-me-in-development
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=240
CORS_ALLOW_ORIGINS=http://localhost:5173
DB_CONN_STR=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost;DATABASE=ERP_PROTHEUS;Trusted_Connection=yes;Encrypt=yes;TrustServerCertificate=yes;
